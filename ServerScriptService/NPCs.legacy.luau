local TweenService= game:GetService("TweenService")
local function walkpath(humanoid, walkTo, reverse)
	local npc = humanoid.Parent
	local root = npc:WaitForChild("HumanoidRootPart")

	local startIndex = reverse and #walkTo or 1
	local endIndex = reverse and 1 or #walkTo
	local step = reverse and -1 or 1

	for i = startIndex, endIndex, step do
		if npc:GetAttribute("stop") then
			humanoid:MoveTo(root.Position)
			return
		end

		local v = walkTo[i]
		humanoid:MoveTo(v.Position)

		local start = tick()

		while tick() - start < 2 do
			if npc:GetAttribute("stop") then
				humanoid:MoveTo(root.Position)
				return
			end

			local distance = (root.Position - v.Position).Magnitude

			if distance < 3 then
				break
			end

			task.wait()
		end
	end
end
